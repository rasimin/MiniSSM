<Window x:Class="SSMS.QueryHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Query Execution History"
        Icon="/Assets/MiniSSMS.ico"
        Width="1180"
        Height="720"
        MinWidth="900"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#181818"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="HistoryButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="82"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="BorderBrush" Value="#4B4B50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#414146"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#29292D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryHistoryButton" TargetType="Button" BasedOn="{StaticResource HistoryButton}">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="BorderBrush" Value="#168BD2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="92"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="210"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#343438"
                BorderThickness="0,0,0,1"
                Padding="14,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="47"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Query Execution History"
                               Foreground="#F0F0F0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="CountText"
                               Text="Loading..."
                               Foreground="#8F8F95"
                               FontSize="11"
                               Margin="12,1,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Refresh"
                            Style="{StaticResource HistoryButton}"
                            Click="RefreshButton_Click"/>
                    <Button x:Name="OpenButton"
                            Content="Open in New Query"
                            MinWidth="138"
                            IsEnabled="False"
                            Style="{StaticResource PrimaryHistoryButton}"
                            Click="OpenButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="From"
                               Foreground="#BEBEC3"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <DatePicker x:Name="FromDatePicker"
                                Width="126"
                                Height="28"
                                Background="#1E1E1E"
                                Foreground="#D4D4D4"
                                BorderBrush="#4A4A4F"/>
                    <TextBlock Text="To"
                               Foreground="#BEBEC3"
                               VerticalAlignment="Center"
                               Margin="12,0,6,0"/>
                    <DatePicker x:Name="ToDatePicker"
                                Width="126"
                                Height="28"
                                Background="#1E1E1E"
                                Foreground="#D4D4D4"
                                BorderBrush="#4A4A4F"/>
                    <TextBlock Text="Database"
                               Foreground="#BEBEC3"
                               VerticalAlignment="Center"
                               Margin="14,0,6,0"/>
                    <TextBox x:Name="DatabaseFilterTextBox"
                             Width="160"
                             Height="28"
                             Padding="7,4"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderBrush="#4A4A4F"
                             KeyDown="FilterTextBox_KeyDown"/>
                    <TextBlock Text="SQL contains"
                               Foreground="#BEBEC3"
                               VerticalAlignment="Center"
                               Margin="14,0,6,0"/>
                    <TextBox x:Name="SqlFilterTextBox"
                             Width="280"
                             Height="28"
                             Padding="7,4"
                             Background="#1E1E1E"
                             Foreground="#D4D4D4"
                             BorderBrush="#4A4A4F"
                             KeyDown="FilterTextBox_KeyDown"/>
                    <Button Content="Apply"
                            MinWidth="68"
                            Style="{StaticResource PrimaryHistoryButton}"
                            Click="ApplyFilterButton_Click"/>
                    <Button Content="Clear"
                            MinWidth="68"
                            Style="{StaticResource HistoryButton}"
                            Click="ClearFilterButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="HistoryGrid"
                  Grid.Row="1"
                  Margin="10"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  SelectionChanged="HistoryGrid_SelectionChanged"
                  MouseDoubleClick="HistoryGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Executed" Binding="{Binding ExecutedAtDisplay}" Width="145"/>
                <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" Width="160"/>
                <DataGridTextColumn Header="Database" Binding="{Binding DatabaseDisplay}" Width="145"/>
                <DataGridTextColumn Header="Status" Binding="{Binding ExecutionStatus}" Width="80"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding DurationDisplay}" Width="90"/>
                <DataGridTextColumn Header="Rows" Binding="{Binding RowsDisplay}" Width="105"/>
                <DataGridTextColumn Header="Query" Binding="{Binding QueryPreview}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2"
                Background="#1E1E1E"
                BorderBrush="#343438"
                BorderThickness="0,1,0,0"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Executed query"
                           Foreground="#BEBEC3"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button x:Name="CopyQueryButton"
                        Grid.Row="0"
                        Content="Copy Query"
                        Height="22"
                        MinWidth="78"
                        Margin="0,0,4,2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        IsEnabled="False"
                        Style="{StaticResource HistoryButton}"
                        Click="CopyQueryButton_Click"/>
                <TextBox x:Name="QueryTextBox"
                         Grid.Row="1"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         Foreground="#D4D4D4"
                         Background="#1E1E1E"
                         BorderBrush="#4A4A4F"
                         BorderThickness="1"
                         SelectionBrush="#264F78"
                         SelectionTextBrush="White"
                         Padding="8,6"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto"/>

                <GridSplitter Grid.Column="1"
                              Grid.RowSpan="2"
                              Width="6"
                              HorizontalAlignment="Stretch"
                              Background="#343438"/>

                <TextBlock Grid.Column="2"
                           Text="Execution message"
                           Foreground="#BEBEC3"
                           FontWeight="SemiBold"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="MessageTextBox"
                         Grid.Column="2"
                         Grid.Row="1"
                         Margin="10,0,0,0"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         Foreground="#D4D4D4"
                         Background="#1E1E1E"
                         BorderBrush="#4A4A4F"
                         BorderThickness="1"
                         SelectionBrush="#264F78"
                         SelectionTextBrush="White"
                         Padding="8,6"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
