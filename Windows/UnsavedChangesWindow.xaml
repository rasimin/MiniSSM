<Window x:Class="SSMS.UnsavedChangesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unsaved Query"
        Width="550"
        Height="224"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Background="Transparent"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="Background" Value="#333337"/>
            <Setter Property="BorderBrush" Value="#4B4B50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#414146"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#68686E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#29292D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDialogButton"
               TargetType="Button"
               BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="BorderBrush" Value="#168BD2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#168BD2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="#202024"
            BorderBrush="#48484E"
            BorderThickness="1"
            CornerRadius="9">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="3"
                              Opacity="0.55"
                              Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#27272B"
                    BorderBrush="#38383D"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Unsaved changes"
                               Margin="16,0,48,0"
                               VerticalAlignment="Center"
                               Foreground="#F1F1F1"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <Button Width="34"
                            Height="30"
                            Margin="0,0,6,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Content="✕"
                            Foreground="#AFAFB5"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Cursor="Hand"
                            Click="CancelButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,20,20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="34"
                        Height="34"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="#4A3D1E"
                        BorderBrush="#806823"
                        BorderThickness="1"
                        CornerRadius="17">
                    <TextBlock Text="!"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#F6C94C"
                               FontFamily="Segoe UI"
                               FontSize="18"
                               FontWeight="Bold"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                    <TextBlock Text="Save this query before closing?"
                               Foreground="#F0F0F0"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="QueryNameText"
                               Margin="0,8,0,0"
                               Foreground="#A8A8AE"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="#252529"
                    BorderBrush="#38383D"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="12,0,14,0">
                    <Button Content="Cancel"
                            Style="{StaticResource DialogButton}"
                            Click="CancelButton_Click"/>
                    <Button Content="Don't Save"
                            Style="{StaticResource DialogButton}"
                            Click="DontSaveButton_Click"/>
                    <Button x:Name="BtnDontSaveAll"
                            Content="Don't Save All"
                            Style="{StaticResource DialogButton}"
                            Visibility="Collapsed"
                            Click="DontSaveAllButton_Click"/>
                    <Button Content="Save"
                            Style="{StaticResource PrimaryDialogButton}"
                            IsDefault="True"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
