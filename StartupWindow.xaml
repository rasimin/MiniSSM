<Window x:Class="SSMS.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniSSMS - Desktop SQL Client"
        Icon="Assets/MiniSSMS.ico"
        Height="760"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="True"
        Background="#181818">
    <Grid Background="#181818">
        <StackPanel Width="260"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <TextBlock Text="MiniSSMS"
                       Foreground="#F2F2F2"
                       FontFamily="Segoe UI"
                       FontSize="30"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Desktop SQL Client"
                       Foreground="#8A8A8A"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       Margin="0,5,0,24"
                       HorizontalAlignment="Center"/>
            <ProgressBar Height="3"
                         IsIndeterminate="True"
                         Foreground="#007ACC"
                         Background="#303030"
                         BorderThickness="0"/>
            <TextBlock x:Name="StatusText"
                       Text="Starting MiniSSMS..."
                       Foreground="#B8B8B8"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       Margin="0,13,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
