<UserControl x:Class="SSMS.QueryTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#1E1E1E">
    <UserControl.Resources>
        <Style x:Key="SchemaActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E6E6E6"/>
            <Setter Property="BorderBrush" Value="#48484C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3A3D"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#606064"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#464649"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SchemaTabCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A8A8A8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="7,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="QueryLayoutGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="EditorRow" Height="3*" MinHeight="60"/>
            <RowDefinition Height="16"/>
            <RowDefinition x:Name="ResultsRow" Height="2*" MinHeight="90"/>
        </Grid.RowDefinitions>

        <!-- Monaco Editor in WebView2 -->
        <Border Grid.Row="0" BorderBrush="#2D2D30" BorderThickness="0,0,0,1">
            <wv2:WebView2 x:Name="SqlEditorWebView" Margin="0" AllowExternalDrop="False"/>
        </Border>

        <!-- Horizontal Grid Splitter -->
        <primitives:Thumb x:Name="EditorResultsSplitter"
                          Grid.Row="1"
                          Height="16"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeNS"
                          DragDelta="EditorResultsSplitter_DragDelta"
                          DragCompleted="EditorResultsSplitter_DragCompleted">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="{x:Type primitives:Thumb}">
                    <Grid Background="Transparent">
                        <Border Height="6"
                                VerticalAlignment="Center"
                                Background="#3A3A3A"/>
                    </Grid>
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>

        <!-- Results & Messages Grid Container -->
        <Grid x:Name="ResultsPane" Grid.Row="2">
            <!-- Results & Messages TabControl -->
            <TabControl x:Name="TabResults" Background="#1E1E1E" BorderThickness="0">
                <TabItem Header="Results">
                    <Grid x:Name="ResultsGridContainer" Background="#1E1E1E"/>
                </TabItem>
                <TabItem Header="Messages">
                    <TextBox x:Name="TxtMessages" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                             Background="#1E1E1E" Foreground="#CCCCCC" BorderThickness="0" FontFamily="Consolas" FontSize="13" IsReadOnly="True" Padding="15"/>
                </TabItem>
            </TabControl>

            <!-- Loading overlay spinner -->
            <Grid x:Name="LoadingOverlay" Background="#B01E1E1E" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="180" Height="4" Foreground="#007ACC" Background="#2D2D30" BorderThickness="0"/>
                    <TextBlock x:Name="LoadingMessageText" Text="Executing query..." Foreground="#CCCCCC"
                               FontSize="12.5" Margin="0,12,0,0" HorizontalAlignment="Center"/>
                    <Button x:Name="CancelQueryButton" Content="Cancel query"
                            Style="{StaticResource SchemaActionButton}"
                            Margin="0,14,0,0" Click="CancelQueryButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
