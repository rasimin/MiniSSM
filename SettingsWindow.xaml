<Window x:Class="SSMS.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Icon="Assets/MiniSSMS.ico"
        Width="520"
        Height="310"
        MinWidth="480"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#181818"
        Foreground="#D4D4D4"
        FontFamily="Segoe UI, Arial">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#F1F1F1"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Application parameters are stored in appsettings.json."
                       Margin="0,5,0,18" Foreground="#999999"/>
        </StackPanel>

        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#2D2D30"
                BorderThickness="1" CornerRadius="4" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Query Execution" FontSize="14" FontWeight="SemiBold" Foreground="#4EC9B0"/>
                <Grid Grid.Row="1" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Command timeout (seconds)" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtCommandTimeout" Grid.Column="1"
                             HorizontalContentAlignment="Right"
                             PreviewTextInput="TxtCommandTimeout_PreviewTextInput"/>
                </Grid>
                <TextBlock Grid.Row="2" Margin="0,9,0,0" Foreground="#999999"
                           Text="Use 0 for no timeout. The value applies to the next query execution."/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Cancel" IsCancel="True"/>
            <Button Content="Save" IsDefault="True" Background="#0E639C"
                    BorderBrush="#1177BB" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
