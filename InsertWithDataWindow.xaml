<Window x:Class="SSMS.InsertWithDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Script INSERT To (with data)" 
        Height="420" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#181A1F"
        BorderBrush="#2A2D35"
        BorderThickness="1">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title / Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header Row -->
        <Grid Grid.Row="0" Margin="0,0,0,20" MouseDown="HeaderGrid_MouseDown" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Script INSERT To (with data)" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="Hasilkan script kueri INSERT SQL dari data tabel berdasarkan kondisi WHERE." Foreground="#888C94" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="✕" Width="20" Height="20" Background="Transparent" BorderThickness="0" Foreground="#888C94" FontSize="12" Click="BtnClose_Click" VerticalAlignment="Top">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="Red"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Content Row -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Tabel:" Foreground="#00ADB5" FontSize="12.5" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBlock x:Name="TxtTableName" Text="dbo.States" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="WHERE Clause (Opsional):" Foreground="#CCCCCC" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <!-- Custom Styled TextBox -->
            <Grid Margin="0,0,0,5">
                <TextBox x:Name="TxtWhereClause" 
                         Background="#25272F" 
                         Foreground="#FFFFFF" 
                         BorderBrush="#3B3F4B" 
                         BorderThickness="1" 
                         Padding="8,10" 
                         FontSize="13"
                         VerticalContentAlignment="Center"
                         TextChanged="TxtWhereClause_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <TextBlock x:Name="TxtPlaceholder" 
                           Text="Contoh: IDAgentStructure = 144" 
                           Foreground="#555860" 
                           IsHitTestVisible="False" 
                           VerticalAlignment="Center" 
                           Margin="10,0,0,0" 
                           FontSize="13"
                           Visibility="Visible"/>
            </Grid>
            
            <TextBlock Text="Kosongkan untuk mengambil semua data (maksimal 1000 baris)." Foreground="#888C94" FontSize="11" Margin="0,0,0,25"/>

            <CheckBox x:Name="ChkUseVariables" Content="Gunakan Variabel T-SQL (DECLARE &amp; SET)" Foreground="#FFFFFF" FontSize="12">
                <CheckBox.Style>
                    <Style TargetType="CheckBox">
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </CheckBox.Style>
            </CheckBox>
        </StackPanel>

        <!-- Buttons Row -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Batal" Width="80" Height="36" Click="BtnClose_Click" Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#25272F"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                        <Setter Property="BorderBrush" Value="#3B3F4B"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#31343F"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button Content="⚙ Generate Script" Width="140" Height="36" Click="BtnGenerate_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#00ADB5"/>
                        <Setter Property="Foreground" Value="#101115"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00C4CE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
