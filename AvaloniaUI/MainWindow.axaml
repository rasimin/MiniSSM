<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:SSMS"
        x:Class="SSMS.MainWindow"
        Title="MiniSSMS - Avalonia SQL Client"
        Width="1180" Height="780" MinWidth="820" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True">
  <Window.KeyBindings>
    <KeyBinding Gesture="F5" Command="{Binding ExecuteCommand}"/>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewQueryCommand}"/>
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}"/>
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
    <KeyBinding Gesture="F8" Command="{Binding ToggleExplorerCommand}"/>
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,Auto,*,24">
    <Menu Background="#252526">
      <MenuItem Header="_File">
        <MenuItem Header="_New Query" Click="NewQuery_OnClick" InputGesture="Ctrl+N"/>
        <MenuItem Header="_Open SQL..." Click="Open_OnClick" InputGesture="Ctrl+O"/>
        <MenuItem Header="_Save" Click="Save_OnClick" InputGesture="Ctrl+S"/>
        <Separator/>
        <MenuItem Header="E_xit" Click="Exit_OnClick"/>
      </MenuItem>
      <MenuItem Header="_Query">
        <MenuItem Header="_Execute" Click="Execute_OnClick" InputGesture="F5"/>
        <MenuItem Header="_Comment Selection" Click="Comment_OnClick"/>
        <MenuItem Header="_Uncomment Selection" Click="Uncomment_OnClick"/>
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Settings" Click="Settings_OnClick"/>
        <MenuItem Header="_Reconnect" Click="Reconnect_OnClick"/>
      </MenuItem>
    </Menu>

    <Border Grid.Row="1" Background="#2D2D30" BorderBrush="#3E3E42"
            BorderThickness="0,0,0,1" Padding="4">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <StackPanel.Styles>
          <Style Selector="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
          </Style>
          <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#3E3E40"/>
          </Style>
          <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#2D2D2D"/>
          </Style>
          <!-- Special styling for the execute button to make it stand out -->
          <Style Selector="Button.execute-btn">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
          </Style>
          <Style Selector="Button.execute-btn:pointerover">
            <Setter Property="Background" Value="#1177BB"/>
          </Style>
          <Style Selector="Button.execute-btn:pressed">
            <Setter Property="Background" Value="#0C5281"/>
          </Style>
        </StackPanel.Styles>

        <Button Content="📄" Click="NewQuery_OnClick" ToolTip.Tip="New Query (Ctrl+N)"/>
        <Button Content="📂" Click="Open_OnClick" ToolTip.Tip="Open SQL File (Ctrl+O)"/>
        <Button Content="💾" Click="Save_OnClick" ToolTip.Tip="Save Query (Ctrl+S)"/>
        <Separator Background="#3E3E42" Width="1" Margin="4,2"/>
        <ComboBox x:Name="DatabaseBox" Width="200" Height="32"
                  SelectionChanged="DatabaseBox_OnSelectionChanged"/>
        <Button Classes="execute-btn" Content="▶" Click="Execute_OnClick" ToolTip.Tip="Execute Query (F5)"/>
        <Button Content="💬" Click="Comment_OnClick" ToolTip.Tip="Comment Selection"/>
        <Button Content="🗨️" Click="Uncomment_OnClick" ToolTip.Tip="Uncomment Selection"/>
        <Button Content="📝" Click="InsertScript_OnClick" ToolTip.Tip="Generate INSERT Script from Table Data"/>
        <Button Content="✕" Click="CloseTab_OnClick" ToolTip.Tip="Close Active Tab"/>
        <Button Content="⚙️" Click="Settings_OnClick" ToolTip.Tip="Settings"/>
      </StackPanel>
    </Border>
 
    <Grid x:Name="MainGrid" Grid.Row="2" ColumnDefinitions="Auto,260,5,*">
      <!-- Collapsed Object Explorer Tab -->
      <Border x:Name="CollapsedExplorerTab" Grid.Column="0" Width="28" Background="#252526" BorderBrush="#2D2D30" BorderThickness="0,0,1,0" IsVisible="False">
        <Button Background="Transparent" BorderThickness="0" Padding="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Click="ShowExplorer_OnClick" ToolTip.Tip="Show Object Explorer">
          <Button.Styles>
            <Style Selector="Button:pointerover">
              <Setter Property="Background" Value="#3E3E40"/>
            </Style>
          </Button.Styles>
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="▶" FontSize="10" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,10,0,15"/>
            <LayoutTransformControl Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
              <LayoutTransformControl.LayoutTransform>
                <RotateTransform Angle="-90"/>
              </LayoutTransformControl.LayoutTransform>
              <TextBlock Text="OBJECT EXPLORER" FontSize="10" FontWeight="SemiBold" Foreground="#CCCCCC"/>
            </LayoutTransformControl>
          </Grid>
        </Button>
      </Border>
 
      <!-- Object Explorer Panel -->
      <Border x:Name="ObjectExplorerBorder" Grid.Column="1" Background="#181818" BorderBrush="#2D2D30" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">
          <Border Background="#252526" Padding="10,7">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
              <TextBlock Text="OBJECT EXPLORER" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
              <Button Grid.Column="1" Content="＋" Padding="6,2" Margin="0,0,4,0" Click="AddConnection_OnClick" ToolTip.Tip="Connect to another SQL Server"/>
              <Button Grid.Column="2" Content="↻" Padding="7,2" Margin="0,0,4,0" Click="RefreshExplorer_OnClick" ToolTip.Tip="Refresh"/>
              <Button Grid.Column="3" Content="◀" Padding="7,2" Click="HideExplorer_OnClick" ToolTip.Tip="Hide Object Explorer"/>
            </Grid>
          </Border>
          <TreeView x:Name="ExplorerTree" Grid.Row="1"
                    ItemsSource="{Binding ExplorerRoots}"
                    DoubleTapped="ExplorerTree_OnDoubleTapped">
            <TreeView.Resources>
              <x:Double x:Key="TreeViewItemIndent">8</x:Double>
              <Thickness x:Key="TreeViewItemExpandCollapseChevronMargin">0,0,-6,0</Thickness>
              <x:Double x:Key="TreeViewItemExpandCollapseChevronSize">10</x:Double>
            </TreeView.Resources>
            <TreeView.Styles>
              <Style Selector="TreeViewItem">
                <Setter Property="ContextMenu" Value="{Binding NodeContextMenu}"/>
                <Setter Property="MinHeight" Value="20"/>
                <Setter Property="Padding" Value="2,1,0,1"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="FontSize" Value="12"/>
              </Style>
              <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron">
                <Setter Property="Width" Value="12"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="MinHeight" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,-8,0"/>
              </Style>
              <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron /template/ Border">
                <Setter Property="Width" Value="12"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
              </Style>
              <Style Selector="TreeViewItem /template/ ToggleButton#PART_ExpandCollapseChevron /template/ Path">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="Stretch" Value="Uniform"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="RenderTransform">
                  <Setter.Value>
                    <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
                  </Setter.Value>
                </Setter>
              </Style>
              <Style Selector="TreeViewItem /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="Margin" Value="0"/>
              </Style>
            </TreeView.Styles>
            <TreeView.DataTemplates>
              <TreeDataTemplate DataType="local:ExplorerNode" ItemsSource="{Binding Children}">
                <TextBlock Text="{Binding Name}" Margin="0"/>
              </TreeDataTemplate>
            </TreeView.DataTemplates>
          </TreeView>
        </Grid>
      </Border>
      <GridSplitter x:Name="ExplorerSplitter" Grid.Column="2" Background="#3A3A3A" ResizeDirection="Columns"/>
      <Grid Grid.Column="3" RowDefinitions="Auto,*">
        <TabControl x:Name="QueryTabs" Grid.Row="0"
                    SelectionChanged="QueryTabs_OnSelectionChanged"
                    Padding="0" Margin="0">
          <TabControl.Styles>
            <Style Selector="TabItem">
              <Setter Property="FontSize" Value="12"/>
              <Setter Property="MinHeight" Value="26"/>
              <Setter Property="Height" Value="26"/>
              <Setter Property="Padding" Value="8, 2, 6, 2"/>
              <Setter Property="Margin" Value="0, 0, 2, 0"/>
              <Setter Property="VerticalAlignment" Value="Center"/>
              <Setter Property="Background" Value="#2D2D2D"/>
              <Setter Property="Foreground" Value="#969696"/>
              <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="TabItem:selected">
              <Setter Property="Background" Value="#1E1E1E"/>
              <Setter Property="Foreground" Value="White"/>
            </Style>
            <Style Selector="TabItem:pointerover">
              <Setter Property="Background" Value="#3E3E40"/>
              <Setter Property="Foreground" Value="White"/>
            </Style>
            <!-- Style for custom close button in tabs -->
            <Style Selector="Button.tab-close-btn">
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Width" Value="14"/>
              <Setter Property="Height" Value="14"/>
              <Setter Property="CornerRadius" Value="7"/>
              <Setter Property="Foreground" Value="#999999"/>
              <Setter Property="HorizontalContentAlignment" Value="Center"/>
              <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style Selector="Button.tab-close-btn:pointerover">
              <Setter Property="Background" Value="#E81123"/>
              <Setter Property="Foreground" Value="White"/>
            </Style>
          </TabControl.Styles>
        </TabControl>
        <Panel x:Name="QueryTabContentContainer" Grid.Row="1" Background="#1E1E1E"/>
      </Grid>
    </Grid>

    <Border Grid.Row="3" Background="#007ACC" Padding="8,2">
      <Grid ColumnDefinitions="*,Auto,20,Auto">
        <TextBlock x:Name="StatusText" Text="Ready" Foreground="White"/>
        <TextBlock x:Name="TimeText" Grid.Column="1" Foreground="White"/>
        <TextBlock x:Name="RowsText" Grid.Column="3" Foreground="White"/>
      </Grid>
    </Border>
  </Grid>
</Window>
