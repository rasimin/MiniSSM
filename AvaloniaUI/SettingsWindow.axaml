<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SSMS.SettingsWindow"
        Title="Settings" Width="520" Height="310"
        MinWidth="480" MinHeight="280"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="22" RowDefinitions="Auto,*,Auto">
    <StackPanel>
      <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
      <TextBlock Text="Application parameters are stored in appsettings.json."
                 Margin="0,5,0,18" Foreground="#999999"/>
    </StackPanel>
    <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#2D2D30"
            BorderThickness="1" CornerRadius="4" Padding="16">
      <Grid RowDefinitions="Auto,Auto,Auto">
        <TextBlock Text="Query Execution" FontSize="14" FontWeight="SemiBold" Foreground="#4EC9B0"/>
        <Grid Grid.Row="1" Margin="0,14,0,0" ColumnDefinitions="*,120">
          <TextBlock Text="Command timeout (seconds)" VerticalAlignment="Center"/>
          <TextBox x:Name="TimeoutBox" Grid.Column="1" HorizontalContentAlignment="Right"/>
        </Grid>
        <TextBlock Grid.Row="2" Margin="0,9,0,0" Foreground="#999999"
                   Text="Use 0 for no timeout. The value applies to the next query execution."/>
      </Grid>
    </Border>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Margin="0,18,0,0" Spacing="8">
      <Button Content="Cancel" Click="Cancel_OnClick"/>
      <Button Content="Save" Background="#0E639C" Click="Save_OnClick"/>
    </StackPanel>
  </Grid>
</Window>
